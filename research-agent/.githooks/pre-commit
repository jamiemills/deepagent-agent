#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
PROJECT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

cd "$PROJECT_ROOT"

printf 'Running Biome checks...\n'
bunx biome check .

printf 'Running ESLint complexity gate...\n'
bun run lint:complexity

printf 'Running Semgrep rule pack...\n'
bun run lint:semgrep

printf 'Running typecheck...\n'
bun run typecheck

printf 'Running test suite...\n'
bun run test
