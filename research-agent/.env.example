BRAVE_SEARCH_API_KEY=your-brave-search-api-key
RESEARCH_AGENT_MODEL_PROVIDER=vertex
RESEARCH_AGENT_MODEL=gemini-3.1-pro-preview

PORT=3001
RESEARCH_API_BASE_URL=http://127.0.0.1:3001
DATA_DIR=.data
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=research-agent

# Optional LangSmith tracing/evals configuration.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=research-agent

# Provider credentials. Set the key for the provider named in
# RESEARCH_AGENT_MODEL_PROVIDER.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Vertex AI / Gemini configuration.
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=
