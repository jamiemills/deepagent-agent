{
  "name": "research-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "research": "bun src/cli.ts local",
    "cli": "bun src/cli.ts",
    "service": "bun src/service/start.ts",
    "worker": "bun src/temporal/worker.ts",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "lint": "bunx biome check .",
    "lint:complexity": "bunx eslint --config eslint.complexity.config.mjs \"src/**/*.ts\" \"test/**/*.ts\" \"vitest.config.ts\"",
    "format": "bunx biome check --write .",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "prepare": "bun scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@langchain/core": "latest",
    "@langchain/google": "latest",
    "@temporalio/client": "^1.11.6",
    "@temporalio/worker": "^1.11.6",
    "@temporalio/workflow": "^1.11.6",
    "deepagents": "latest",
    "dotenv": "^16.4.7",
    "effect": "^3.13.8",
    "fastify": "^5.2.1",
    "langchain": "latest",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.14.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitest/coverage-v8": "^4.1.2",
    "ajv": "^6.12.6",
    "eslint": "^9.39.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
