{
  "name": "research-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "research": "bun src/cli.ts local",
    "cli": "bun src/cli.ts",
    "service": "bun src/service/start.ts",
    "worker": "bun src/temporal/worker.ts",
    "test": "bun x --bun vitest run",
    "test:providers": "bun x --bun vitest run test/provider-*.test.ts",
    "test:provider:openai": "bun x --bun vitest run test/provider-openai.test.ts",
    "test:provider:openai-codex": "bun x --bun vitest run test/provider-openai-codex.test.ts",
    "test:provider:anthropic": "bun x --bun vitest run test/provider-anthropic.test.ts",
    "test:provider:vertex": "bun x --bun vitest run test/provider-vertex.test.ts",
    "test:watch": "bun x --bun vitest",
    "lint": "bunx biome check .",
    "check:fast": "printf 'Running Biome checks...\\n' && bunx biome check . && printf 'Running staged policy gate...\\n' && bun run policy:diff && printf 'Running ESLint complexity gate...\\n' && bun run lint:complexity",
    "lint:complexity": "bunx eslint --config eslint.complexity.config.mjs \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:typed": "bunx eslint --config eslint.typed.config.mjs \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:semgrep": "semgrep scan --quiet --config semgrep/rules src test biome.json eslint.complexity.config.mjs package.json tsconfig.json .githooks",
    "test:semgrep": "semgrep test semgrep/rules",
    "agent-policy": "bun run policy:diff && bun run verify && bun run lint:typed",
    "policy:diff": "bun scripts/check-diff-policies.mjs",
    "format": "bunx biome check --write .",
    "typecheck": "bunx tsc -p tsconfig.json",
    "verify": "printf 'Running Biome checks...\\n' && bunx biome check . && printf 'Running typecheck...\\n' && bun run typecheck && printf 'Running ESLint complexity gate...\\n' && bun run lint:complexity && printf 'Running Semgrep rule pack...\\n' && bun run lint:semgrep && printf 'Running test suite...\\n' && bun run test",
    "prepare": "bun scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "@langchain/google": "^0.1.10",
    "@langchain/openai": "^1.4.2",
    "@temporalio/client": "^1.11.6",
    "@temporalio/worker": "^1.11.6",
    "@temporalio/workflow": "^1.11.6",
    "deepagents": "latest",
    "dotenv": "^16.4.7",
    "effect": "^3.13.8",
    "fastify": "^5.2.1",
    "langchain": "^1.3.0",
    "zod": "^3.24.2"
  },
  "overrides": {
    "@langchain/core": "^1.1.39",
    "langchain": "^1.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@eslint/js": "^10.0.1",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.14.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitest/coverage-v8": "^4.1.2",
    "ajv": "^6.12.6",
    "eslint": "^9.39.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
